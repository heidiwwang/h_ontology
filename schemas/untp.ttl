@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix untp: <https://vocabulary.uncefact.org/untp/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

untp:Address a rdfs:Class ;
    rdfs:label "Address" ;
    rdfs:comment "A postal address. Reuses streetAddress, postalCode, addressLocality, and addressRegion from schema.org PostalAddress. Extends with addressCountry (an ISO-3166 country code/name structure)." ;
    untp:extendsModel schema:PostalAddress .

untp:AggregationType a rdfs:Class ;
    rdfs:label "AggregationType" ;
    rdfs:comment "Indicates how to aggregate multiple values to report a single performance metric." .

untp:AssessmentLevel a rdfs:Class ;
    rdfs:label "AssessmentLevel" ;
    rdfs:comment "Type of authority endorsement of the assessment process" .

untp:AssessmentSubjectType a rdfs:Class ;
    rdfs:label "AssessmentSubjectType" ;
    rdfs:comment "The type of entity being assessed." .

untp:AssessorLevel a rdfs:Class ;
    rdfs:label "AssessorLevel" ;
    rdfs:comment "Code that describes the level of independent assurance of the specific assessment" .

untp:AttestationType a rdfs:Class ;
    rdfs:label "AttestationType" ;
    rdfs:comment "A code for the type of the attestation credential" .

untp:BitstringStatusListEntry a rdfs:Class ;
    rdfs:label "BitstringStatusListEntry" ;
    rdfs:comment "A privacy-preserving, space-efficient, and high-performance mechanism for publishing status information such as suspension or revocation of Verifiable Credentials through use of bitstrings.  See https://www.w3.org/TR/vc-bitstring-status-list/ for full details." .

untp:Characteristics a rdfs:Class ;
    rdfs:label "Characteristics" ;
    rdfs:comment "A declaration of conformance with one or more criteria from a specific standard or regulation.  " .

untp:Claim a rdfs:Class ;
    rdfs:label "Claim" ;
    rdfs:comment "A performance claim about a product, facility, or organisation that is made against a well defined criterion." .

untp:Classification a rdfs:Class ;
    rdfs:label "Classification" ;
    rdfs:comment "A classification scheme and code / name representing a category value for a product, entity, or facility." .

untp:ConformityAssessment a rdfs:Class ;
    rdfs:label "ConformityAssessment" ;
    rdfs:comment "A specific assessment about the product or facility against a specific specification.  Eg the carbon intensity of a given product or batch." .

untp:ConformityAttestation a rdfs:Class ;
    rdfs:label "ConformityAttestation" ;
    rdfs:comment "A conformity attestation issued by a competent body that defines one or more assessments (eg carbon intensity) about a product (eg battery) against a specification (eg LCA method) defined in a standard or regulation." .

untp:ConformityProfile a rdfs:Class ;
    rdfs:label "ConformityProfile" ;
    rdfs:comment "A versioned conformity profile, managed under a scheme, which includes a specific list of versioned criteria. A conformity profile represents the precise scope of a conformity attestation. " .

untp:ConformityScheme a rdfs:Class ;
    rdfs:label "ConformityScheme" ;
    rdfs:comment "A formal governance scheme under which an attestation is issued (eg ACRS structural steel certification) " .

untp:ConformityTopic a rdfs:Class ;
    rdfs:label "ConformityTopic" ;
    rdfs:comment "The UNTP standard classification scheme for conformity topic.  see http://vocabulary.uncefact.org/ConformityTopic" .

untp:Coordinate a rdfs:Class ;
    rdfs:label "Coordinate" ;
    rdfs:comment "A geographic point defined by latitude and longitude using the WGS84 geodetic coordinate reference system (EPSG:4326). Latitude and longitude are expressed in decimal degrees as floating-point numbers. Coordinates follow the conventional order (latitude, longitude) and represent a point on the Earth’s surface." .

untp:Country a rdfs:Class ;
    rdfs:label "Country" ;
    rdfs:comment "Country Code and Name from ISO 3166" .

untp:CountryCode a rdfs:Class ;
    rdfs:label "CountryCode" ;
    rdfs:comment "ISO 2 letter country code" .

untp:CredentialIssuer a rdfs:Class ;
    rdfs:label "CredentialIssuer" ;
    rdfs:comment "The issuer party (person or organisation) of a verifiable credential." .

untp:CredentialStatus a rdfs:Class ;
    rdfs:label "CredentialStatus" ;
    rdfs:comment "The status purpose of a credential status entry within a W3C Verifiable Credential, indicating the type of status check that can be performed (e.g. revocation, suspension, refresh, or message)." .

untp:Criterion a rdfs:Class ;
    rdfs:label "Criterion" ;
    rdfs:comment "A specific rule or criterion within a standard or regulation. eg a carbon intensity calculation rule within an emissions standard." .

untp:CriterionStatus a rdfs:Class ;
    rdfs:label "CriterionStatus" ;
    rdfs:comment "The status of the conformity profile or criterion" .

untp:DigitalConformityCredential a rdfs:Class ;
    rdfs:label "DigitalConformityCredential" ;
    rdfs:comment "A Digital Conformity Credential (DCC) credential." ;
    rdfs:subClassOf "untp:VerifiableCredential" ;
    untp:credentialSubjectType untp:ConformityAttestation .

untp:DigitalFacilityRecord a rdfs:Class ;
    rdfs:label "DigitalFacilityRecord" ;
    rdfs:comment "A digital Facility Record (DFR) credential." ;
    rdfs:subClassOf "untp:VerifiableCredential" ;
    untp:credentialSubjectType untp:Facility .

untp:DigitalIdentityAnchor a rdfs:Class ;
    rdfs:label "DigitalIdentityAnchor" ;
    rdfs:comment "The Digital Identity Anchor (DIA) is a very simple credential that is issued by a trusted authority and asserts an equivalence between a member identity as known to the authority (eg a VAT number) and one or more decentralised identifiers (DIDs) held by the member." ;
    rdfs:subClassOf "untp:VerifiableCredential" ;
    untp:credentialSubjectType untp:RegisteredIdentity .

untp:DigitalProductPassport a rdfs:Class ;
    rdfs:label "DigitalProductPassport" ;
    rdfs:comment "A digital Product Passport (DPP) credential." ;
    rdfs:subClassOf "untp:VerifiableCredential" ;
    untp:credentialSubjectType untp:Product .

untp:DigitalTraceabilityEvent a rdfs:Class ;
    rdfs:label "DigitalTraceabilityEvent" ;
    rdfs:comment "A Digital Traceability Event (DTE) credential." ;
    rdfs:subClassOf "untp:VerifiableCredential" ;
    untp:credentialSubjectType untp:LifecycleEvent .

untp:Dimension a rdfs:Class ;
    rdfs:label "Dimension" ;
    rdfs:comment "Overall (length, width, height) dimensions and weight/volume of an item." .

untp:Endorsement a rdfs:Class ;
    rdfs:label "Endorsement" ;
    rdfs:comment "The authority under which a conformity claim is issued.  For example a national accreditation authority may authorise a test lab to issue test certificates about a product against a standard. " .

untp:Entity a rdfs:Class ;
    rdfs:label "Entity" ;
    rdfs:comment "A uniquely identified entity" .

untp:EventProduct a rdfs:Class ;
    rdfs:label "EventProduct" ;
    rdfs:comment "A quantity of products or materials involved in a lifecycle event." .

untp:Facility a rdfs:Class ;
    rdfs:label "Facility" ;
    rdfs:comment "The physical site (eg farm or factory) where the product or materials was produced." .

untp:FacilityVerification a rdfs:Class ;
    rdfs:label "FacilityVerification" ;
    rdfs:comment "The facility which is the subject of this conformity assessment" .

untp:IdentifierScheme a rdfs:Class ;
    rdfs:label "IdentifierScheme" ;
    rdfs:comment "An identifier registration scheme for products, facilities, or organisations. Typically operated by a state, national or global authority." .

untp:Image a rdfs:Class ;
    rdfs:label "Image" ;
    rdfs:comment "A binary image encoded as base64 text and embedded into the data.  Use this for small images like certification trust marks or regulated labels.  Large images should be external links." .

untp:ImprovementIndicator a rdfs:Class ;
    rdfs:label "ImprovementIndicator" ;
    rdfs:comment "Indicator of whether conforming performance is greater than or less than the defined threshold." .

untp:IssuingSoftware a rdfs:Class ;
    rdfs:label "IssuingSoftware" ;
    rdfs:comment "Optional metadata identifying the software product (and its vendor) that issued the parent credential. Used for vendor traceability and conformity testing." .

untp:LicenseType a rdfs:Class ;
    rdfs:label "LicenseType" ;
    rdfs:comment "The license type of the published vocabulary" .

untp:LifecycleEvent a rdfs:Class ;
    rdfs:label "LifecycleEvent" ;
    rdfs:comment "This abstract event structure provides a common language to describe product lifecycle events such as shipments, inspections, manufacturing processes, etc." .

untp:Link a rdfs:Class ;
    rdfs:label "Link" ;
    rdfs:comment "A structure to provide a URL link plus metadata associated with the link." .

untp:Location a rdfs:Class ;
    rdfs:label "Location" ;
    rdfs:comment "Location information including address and geo-location of points, areas, and boundaries. At least one of plusCode, geoLocation, or geoBoundary are required." .

untp:MakeEvent a rdfs:Class ;
    rdfs:label "MakeEvent" ;
    rdfs:comment "Transformation (manufacture/  production) of input products to output products at a given facility." ;
    rdfs:subClassOf "untp:LifecycleEvent" .

untp:Material a rdfs:Class ;
    rdfs:label "Material" ;
    rdfs:comment "The material class encapsulates details about the origin or source of raw materials in a product, including the country of origin and the mass fraction." .

untp:MaterialUsage a rdfs:Class ;
    rdfs:label "MaterialUsage" ;
    rdfs:comment "A material usage record defining the consumption of materials for a given period, typically at an operating facility.  Used to specify volumetric consumption and country of origin without specifying specific suppliers." .

untp:Measure a rdfs:Class ;
    rdfs:label "Measure" ;
    rdfs:comment "The measure class defines a numeric measured value (eg 10) and a coded unit of measure (eg KG).  There is an optional upper and lower tolerance which can be used to specify uncertainty in the measure.  " .

untp:MimeType a rdfs:Class ;
    rdfs:label "MimeType" ;
    rdfs:comment "IANA multipart media encoding type " .

untp:ModifyEvent a rdfs:Class ;
    rdfs:label "ModifyEvent" ;
    rdfs:comment "Intervention (eg repair) on a product without changing it's identity at a given facility." ;
    rdfs:subClassOf "untp:LifecycleEvent" .

untp:MoveEvent a rdfs:Class ;
    rdfs:label "MoveEvent" ;
    rdfs:comment "Transfer (shipment) of products from one facility to another." ;
    rdfs:subClassOf "untp:LifecycleEvent" .

untp:Package a rdfs:Class ;
    rdfs:label "Package" ;
    rdfs:comment "Details of product packaging" .

untp:Party a rdfs:Class ;
    rdfs:label "Party" ;
    rdfs:comment "An organisation.  May be a supply chain actor, a certifier, a government agency." .

untp:PartyRole a rdfs:Class ;
    rdfs:label "PartyRole" ;
    rdfs:comment "A party with a defined relationship to the referencing entity",
        "The role for this facility - party or product - party relationship" .

untp:Performance a rdfs:Class ;
    rdfs:label "Performance" ;
    rdfs:comment "A claimed, assessed, or required performance level defined either by a scoring system or a numeric measure." .

untp:PerformanceMetric a rdfs:Class ;
    rdfs:label "PerformanceMetric" ;
    rdfs:comment "A standardised data point for performance reporting (eg product carbon footprint)" .

untp:Period a rdfs:Class ;
    rdfs:label "Period" ;
    rdfs:comment "A period of time, typically a month, quarter or a year, which defines the context boundary for reported facts." .

untp:Product a rdfs:Class ;
    rdfs:label "Product" ;
    rdfs:comment "The ProductInformation class encapsulates detailed information regarding a specific product, including its identification details, manufacturer, and other pertinent details." .

untp:ProductIDGranularity a rdfs:Class ;
    rdfs:label "ProductIDGranularity" ;
    rdfs:comment "Product identification granularity" .

untp:ProductStatus a rdfs:Class ;
    rdfs:label "ProductStatus" ;
    rdfs:comment "The lifecycle status of a product, describing its current state from initial production through to eventual disposal or recycling. Used as the value of the disposition property on EventProduct in traceability events." .

untp:ProductVerification a rdfs:Class ;
    rdfs:label "ProductVerification" ;
    rdfs:comment "The product which is the subject of this conformity assessment" .

untp:RegisteredIdentity a rdfs:Class ;
    rdfs:label "RegisteredIdentity" ;
    rdfs:comment "The identity anchor is a mapping between a registry member identity and one or more decentralised identifiers owned by the member. It may also list a set of membership scopes." .

untp:RegistryType a rdfs:Class ;
    rdfs:label "RegistryType" ;
    rdfs:comment "A registry category code." .

untp:Regulation a rdfs:Class ;
    rdfs:label "Regulation" ;
    rdfs:comment "A regulation (eg EU deforestation regulation) that defines the criteria for assessment." .

untp:RegulatoryAlignment a rdfs:Class ;
    rdfs:label "RegulatoryAlignment" ;
    rdfs:comment "A national regulation or international treaty and an alignment level (exceeds, meets, partial)." .

untp:RenderTemplate2024 a rdfs:Class ;
    rdfs:label "RenderTemplate2024" ;
    rdfs:comment "A single template format focused render method where the content/media type decision becomes secondary (and is expressed separately).See https://github.com/w3c-ccg/vc-render-method/issues/9" .

untp:SchemeAlignmentLevel a rdfs:Class ;
    rdfs:label "SchemeAlignmentLevel" ;
    rdfs:comment "Alignment level of a scheme profile or criterion against a reference standard or regulation" .

untp:SchemeEndorsementLevel a rdfs:Class ;
    rdfs:label "SchemeEndorsementLevel" ;
    rdfs:comment "The level of endorsement or recognition that a conformity scheme has received from authoritative bodies, indicating the degree of independent assurance over the scheme's credibility and rigour." .

untp:Score a rdfs:Class ;
    rdfs:label "Score" ;
    rdfs:comment "A single score within a scoring framework. " .

untp:ScoringFramework a rdfs:Class ;
    rdfs:label "ScoringFramework" ;
    rdfs:comment "A scoring framework used for performance level assessments against a criteria or scheme. For example forced labour performance might score A to D depending on the percentage of workforce subject to recruitment fees." .

untp:SensorData a rdfs:Class ;
    rdfs:label "SensorData" ;
    rdfs:comment "A sensor data recording associated with this event" .

untp:SoftwareVendor a rdfs:Class ;
    rdfs:label "SoftwareVendor" ;
    rdfs:comment "The vendor of a software product that issued a UNTP credential." .

untp:Standard a rdfs:Class ;
    rdfs:label "Standard" ;
    rdfs:comment "A standard (eg ISO 14000) that specifies the criteria for conformance." .

untp:StandardAlignment a rdfs:Class ;
    rdfs:label "StandardAlignment" ;
    rdfs:comment "A voluntary standard and an alignment level (exceeds, meets, partial)." .

untp:UnitOfMeasure a rdfs:Class ;
    rdfs:label "UnitOfMeasure" ;
    rdfs:comment "UNECE Recommendation 20 Unit of Measure codelist" .

untp:VerifiableCredential a rdfs:Class ;
    rdfs:label "VerifiableCredential" ;
    rdfs:comment "A verifiable credential is a digital and verifiable version of everyday credentials such as certificates and licenses. It conforms to the W3C Verifiable Credentials Data Model v2.0 (VCDM)." ;
    untp:extendsModel <https://www.w3.org/2018/credentials#VerifiableCredential> .

untp: a owl:Ontology ;
    dcterms:description "Core classes and properties for the UNTP data model (JSON-LD/RDF)." ;
    dcterms:title "UNTP Core Vocabulary" ;
    vann:preferredNamespacePrefix "untp" ;
    vann:preferredNamespaceUri "https://vocabulary.uncefact.org/untp/" ;
    owl:versionInfo "working" .

<https://vocabulary.uncefact.org/untp/AggregationType#latest> a untp:AggregationType ;
    rdfs:label "latest" ;
    rdf:value "latest" ;
    rdfs:comment "Only the most recent value is meaningful (e.g. a biodiversity assessment score where only the current state matters)" .

<https://vocabulary.uncefact.org/untp/AggregationType#sum> a untp:AggregationType ;
    rdfs:label "sum" ;
    rdf:value "sum" ;
    rdfs:comment "Values add up (e.g. total GHG emissions across all facilities = sum of each facility's emissions)" .

<https://vocabulary.uncefact.org/untp/AggregationType#weighted-average> a untp:AggregationType ;
    rdfs:label "weighted-average" ;
    rdf:value "weighted-average" ;
    rdfs:comment "Values must be averaged weighted by volume/output (e.g. emissions intensity per kg across suppliers)" .

<https://vocabulary.uncefact.org/untp/AssessmentLevel#authority-benchmark> a untp:AssessmentLevel ;
    rdfs:label "Authority-derived assurance: Recognition by approved benchmarking organisation" ;
    rdf:value "authority-benchmark" ;
    rdfs:comment """Benchmarking of scheme by an organization approved to UNIDO benchmarking
principles and process. UNIDO Global Best Practice Framework for Organisations Performing Benchmarking Activities for Certification-related Conformity Assessment Schemes 2026""" .

<https://vocabulary.uncefact.org/untp/AssessmentLevel#authority-extended-mra> a untp:AssessmentLevel ;
    rdfs:label "Authority- derived assurance: Peer assessment body recognition for accredited CAB" ;
    rdf:value "authority-extended-mra" ;
    rdfs:comment "Independent peer assessment for accredited CAB. This pathway applies to CABs accredited under the Mutual Recognition Arrangement of the Global Accreditation Cooperation Incorporated. Schemes used by CABs may be owned by the peer assessment body but the CAB itself shall not be owned by or otherwise related to the peer assessment body." .

<https://vocabulary.uncefact.org/untp/AssessmentLevel#authority-globalmra> a untp:AssessmentLevel ;
    rdfs:label "Authority-derived assurance:Global accreditation mutual recognition arrangement" ;
    rdf:value "authority-globalmra" ;
    rdfs:comment """Accreditation of CAB under global mutual recognition arrangement by a body peer-evaluated
to ISO/IEC 17011. Scheme evaluation is a prerequisite for accreditation of CABs by bodies that are signatories to the Global Accreditation Cooperation Incorporated Mutual Recognition Arrangement.""" .

<https://vocabulary.uncefact.org/untp/AssessmentLevel#authority-mandate> a untp:AssessmentLevel ;
    rdfs:label "Authority-derived assurance: Recognition by government mandate" ;
    rdf:value "authority-mandate" ;
    rdfs:comment "Government mandate for conformity assessment activity. Ownership or mandate provided by national government or intergovernmental entity." .

<https://vocabulary.uncefact.org/untp/AssessmentLevel#authority-peer> a untp:AssessmentLevel ;
    rdfs:label "Authority-derived assurance: Recognition by a governmental peer assessment authority" ;
    rdf:value "authority-peer" ;
    rdfs:comment "Peer assessment process managed by government. Ownership or mandate provided by national government or intergovernmental entity." .

<https://vocabulary.uncefact.org/untp/AssessmentLevel#no-endorsement> a untp:AssessmentLevel ;
    rdfs:label "No endorsement." ;
    rdf:value "no-endorsement" ;
    rdfs:comment "conformity assessment claiming no external authority or else unspecified" .

<https://vocabulary.uncefact.org/untp/AssessmentLevel#scheme-cab> a untp:AssessmentLevel ;
    rdfs:label "Scheme-derived assurance: Recognition of CAB by registered scheme" ;
    rdf:value "scheme-cab" ;
    rdfs:comment "Scheme owner recognition of other parties assessing against the scheme standards. The linked scheme self-declaration can be used to assist in judging credibility of the scheme. Users of conformity credentials issued by a CAB recognised under a scheme may refer to the linked scheme self-declaration for details of the CAB-approval process used by the scheme owner" .

<https://vocabulary.uncefact.org/untp/AssessmentLevel#scheme-self> a untp:AssessmentLevel ;
    rdfs:label "Scheme-derived assurance: Self-declaration by registered scheme" ;
    rdf:value "scheme-self" ;
    rdfs:comment "Scheme owner directly conducting conformity assessment activities. The linked scheme self-declaration can be used to assist in judging credibility of the scheme." .

<https://vocabulary.uncefact.org/untp/AssessmentSubjectType#facility> a untp:AssessmentSubjectType ;
    rdfs:label "Facility" ;
    rdf:value "facility" ;
    rdfs:comment "The conformity profile targets facilities — assessing the operational practices, environmental performance, or working conditions at a specific site." .

<https://vocabulary.uncefact.org/untp/AssessmentSubjectType#organisation> a untp:AssessmentSubjectType ;
    rdfs:label "Organisation" ;
    rdf:value "organisation" ;
    rdfs:comment "The conformity profile targets organisations — assessing entity-level governance, policies, management systems, or corporate sustainability performance." .

<https://vocabulary.uncefact.org/untp/AssessmentSubjectType#product> a untp:AssessmentSubjectType ;
    rdfs:label "Product" ;
    rdf:value "product" ;
    rdfs:comment "The conformity profile targets products — assessing characteristics, composition, performance, or safety of manufactured goods." .

<https://vocabulary.uncefact.org/untp/AssessorLevel#3rdParty> a untp:AssessorLevel ;
    rdfs:label "Independent third party assessment" ;
    rdf:value "3rdParty" ;
    rdfs:comment " 3rd party (independent) conformity assessment" .

<https://vocabulary.uncefact.org/untp/AssessorLevel#buyer> a untp:AssessorLevel ;
    rdfs:label "Buyer assessment" ;
    rdf:value "buyer" ;
    rdfs:comment " conformity assessment by potential purchaser" .

<https://vocabulary.uncefact.org/untp/AssessorLevel#commercial> a untp:AssessorLevel ;
    rdfs:label "Commercial assessment" ;
    rdf:value "commercial" ;
    rdfs:comment " conformity assessment by related body or under commercial contract" .

<https://vocabulary.uncefact.org/untp/AssessorLevel#hybrid> a untp:AssessorLevel ;
    rdfs:label "Input from self-declaring parties" ;
    rdf:value "hybrid" ;
    rdfs:comment "2nd or 3rd party conformity assessment that is dependent on the accuracy of information provided by self-declaring parties" .

<https://vocabulary.uncefact.org/untp/AssessorLevel#membership> a untp:AssessorLevel ;
    rdfs:label "Industry body assessment" ;
    rdf:value "membership" ;
    rdfs:comment " conformity assessment by industry representative body or membership body" .

<https://vocabulary.uncefact.org/untp/AssessorLevel#self> a untp:AssessorLevel ;
    rdfs:label "Self assessed" ;
    rdf:value "self" ;
    rdfs:comment " self-assessment" .

<https://vocabulary.uncefact.org/untp/AssessorLevel#unspecified> a untp:AssessorLevel ;
    rdfs:label "No independent assessment" ;
    rdf:value "unspecified" ;
    rdfs:comment " conformity assessment by party with unspecified relationship " .

<https://vocabulary.uncefact.org/untp/AttestationType#calibration> a untp:AttestationType ;
    rdfs:label "calibration" ;
    rdf:value "calibration" ;
    rdfs:comment "An equipment calibration report" .

<https://vocabulary.uncefact.org/untp/AttestationType#certification> a untp:AttestationType ;
    rdfs:label "certification" ;
    rdf:value "certification" ;
    rdfs:comment "A formal third party certification of conformity" .

<https://vocabulary.uncefact.org/untp/AttestationType#declaration> a untp:AttestationType ;
    rdfs:label "declaration" ;
    rdf:value "declaration" ;
    rdfs:comment "A self assessed declaration of conformity" .

<https://vocabulary.uncefact.org/untp/AttestationType#inspection> a untp:AttestationType ;
    rdfs:label "inspection" ;
    rdf:value "inspection" ;
    rdfs:comment "An Inspection report " .

<https://vocabulary.uncefact.org/untp/AttestationType#testing> a untp:AttestationType ;
    rdfs:label "testing" ;
    rdf:value "testing" ;
    rdfs:comment "A test report" .

<https://vocabulary.uncefact.org/untp/AttestationType#validation> a untp:AttestationType ;
    rdfs:label "validation" ;
    rdf:value "validation" ;
    rdfs:comment "A validation report" .

<https://vocabulary.uncefact.org/untp/AttestationType#verification> a untp:AttestationType ;
    rdfs:label "verification" ;
    rdf:value "verification" ;
    rdfs:comment "A verification report" .

<https://vocabulary.uncefact.org/untp/CredentialStatus#message> a untp:CredentialStatus ;
    rdfs:label "message" ;
    rdf:value "message" ;
    rdfs:comment "Used to indicate a ussuer specified flexible status message associated with a verifiable credential. The status message descriptions MUST be defined in credentialSubject.statusMessages. credentialSubject.statusSize MUST be specified when this statusPurpose value is used." .

<https://vocabulary.uncefact.org/untp/CredentialStatus#refresh> a untp:CredentialStatus ;
    rdfs:label "refresh" ;
    rdf:value "refresh" ;
    rdfs:comment "Used to signal that an updated verifiable credential is available via the credential's refresh service feature. This status does not invalidate the verifiable credential and is not reversible." .

<https://vocabulary.uncefact.org/untp/CredentialStatus#revocation> a untp:CredentialStatus ;
    rdfs:label "revocation" ;
    rdf:value "revocation" ;
    rdfs:comment "Used to cancel the validity of a verifiable credential. This status is not reversible." .

<https://vocabulary.uncefact.org/untp/CredentialStatus#suspension> a untp:CredentialStatus ;
    rdfs:label "suspension" ;
    rdf:value "suspension" ;
    rdfs:comment "Used to temporarily prevent the acceptance of a verifiable credential. This status is reversible." .

<https://vocabulary.uncefact.org/untp/CriterionStatus#active> a untp:CriterionStatus ;
    rdfs:label "Active" ;
    rdf:value "active" ;
    rdfs:comment "The criterion is in active use." .

<https://vocabulary.uncefact.org/untp/CriterionStatus#deprecated> a untp:CriterionStatus ;
    rdfs:label "Deprecated" ;
    rdf:value "deprecated" ;
    rdfs:comment "The criterion is deprecated." .

<https://vocabulary.uncefact.org/untp/CriterionStatus#proposed> a untp:CriterionStatus ;
    rdfs:label "Proposed" ;
    rdf:value "proposed" ;
    rdfs:comment "The criterion is proposed" .

<https://vocabulary.uncefact.org/untp/ImprovementIndicator#higher> a untp:ImprovementIndicator ;
    rdfs:label "higher" ;
    rdf:value "higher" ;
    rdfs:comment "Performance improves with a higher measured value" .

<https://vocabulary.uncefact.org/untp/ImprovementIndicator#lower> a untp:ImprovementIndicator ;
    rdfs:label "lower" ;
    rdf:value "lower" ;
    rdfs:comment "Performance improves with a lower measured value" .

<https://vocabulary.uncefact.org/untp/LicenseType#copyleft> a untp:LicenseType ;
    rdfs:label "Copyleft" ;
    rdf:value "copyleft" ;
    rdfs:comment "Platforms, infrastructure. Restrictiveness - Medium–high" .

<https://vocabulary.uncefact.org/untp/LicenseType#creative-Commons> a untp:LicenseType ;
    rdfs:label "Creative Commons" ;
    rdf:value "creative-Commons" ;
    rdfs:comment "Media, publications. Restrictiveness - Variable" .

<https://vocabulary.uncefact.org/untp/LicenseType#permissive-OpenSource> a untp:LicenseType ;
    rdfs:label "Permissive open source" ;
    rdf:value "permissive-OpenSource" ;
    rdfs:comment "Libraries, frameworks. Restrictiveness - Low" .

<https://vocabulary.uncefact.org/untp/LicenseType#proprietary-Code> a untp:LicenseType ;
    rdfs:label "Proprietary" ;
    rdf:value "proprietary-Code" ;
    rdfs:comment "Commercial software, internal docs. Restrictiveness - Very high" .

<https://vocabulary.uncefact.org/untp/LicenseType#proprietary-Document> a untp:LicenseType ;
    rdfs:label "Documentation licenses" ;
    rdf:value "proprietary-Document" ;
    rdfs:comment "Manuals, standards. Restrictiveness - Medium" .

<https://vocabulary.uncefact.org/untp/LicenseType#public> a untp:LicenseType ;
    rdfs:label "Public domain" ;
    rdf:value "public" ;
    rdfs:comment "Data, examples. Restrictiveness - None" .

<https://vocabulary.uncefact.org/untp/LicenseType#source-Available> a untp:LicenseType ;
    rdfs:label "Source-available" ;
    rdf:value "source-Available" ;
    rdfs:comment "Commercial SaaS vendors. Restrictiveness - Medium–high" .

<https://vocabulary.uncefact.org/untp/PartyRole#brandOwner> a untp:PartyRole ;
    rdfs:label "Party responsible for the brand or product specification" ;
    rdf:value "brandOwner" .

<https://vocabulary.uncefact.org/untp/PartyRole#carrier> a untp:PartyRole ;
    rdfs:label "Party physically transporting the goods" ;
    rdf:value "carrier" .

<https://vocabulary.uncefact.org/untp/PartyRole#certifier> a untp:PartyRole ;
    rdfs:label "Party issuing certification or conformity assessment" ;
    rdf:value "certifier" .

<https://vocabulary.uncefact.org/untp/PartyRole#consignee> a untp:PartyRole ;
    rdfs:label "Party receiving the goods" ;
    rdf:value "consignee" .

<https://vocabulary.uncefact.org/untp/PartyRole#consignor> a untp:PartyRole ;
    rdfs:label "Party sending the goods" ;
    rdf:value "consignor" .

<https://vocabulary.uncefact.org/untp/PartyRole#distributor> a untp:PartyRole ;
    rdfs:label "Party distributing goods in the supply chain" ;
    rdf:value "distributor" .

<https://vocabulary.uncefact.org/untp/PartyRole#exporter> a untp:PartyRole ;
    rdfs:label "Party exporting the goods from a jurisdiction" ;
    rdf:value "exporter" .

<https://vocabulary.uncefact.org/untp/PartyRole#importer> a untp:PartyRole ;
    rdfs:label "Party importing the goods into a jurisdiction" ;
    rdf:value "importer" .

<https://vocabulary.uncefact.org/untp/PartyRole#inspector> a untp:PartyRole ;
    rdfs:label "Party performing inspection or testing" ;
    rdf:value "inspector" .

<https://vocabulary.uncefact.org/untp/PartyRole#logisticsProvider> a untp:PartyRole ;
    rdfs:label "Party responsible for logistics operations" ;
    rdf:value "logisticsProvider" .

<https://vocabulary.uncefact.org/untp/PartyRole#manufacturer> a untp:PartyRole ;
    rdfs:label "Party that manufactures or assembles the product" ;
    rdf:value "manufacturer" .

<https://vocabulary.uncefact.org/untp/PartyRole#operator> a untp:PartyRole ;
    rdfs:label "Party operating a facility or process" ;
    rdf:value "operator" .

<https://vocabulary.uncefact.org/untp/PartyRole#owner> a untp:PartyRole ;
    rdfs:label "Party that owns the product or asset" ;
    rdf:value "owner" .

<https://vocabulary.uncefact.org/untp/PartyRole#processor> a untp:PartyRole ;
    rdfs:label "Party that processes or transforms materials" ;
    rdf:value "processor" .

<https://vocabulary.uncefact.org/untp/PartyRole#producer> a untp:PartyRole ;
    rdfs:label "Party that extracts, grows, or produces raw materials" ;
    rdf:value "producer" .

<https://vocabulary.uncefact.org/untp/PartyRole#recycler> a untp:PartyRole ;
    rdfs:label "Party that recovers materials from products" ;
    rdf:value "recycler" .

<https://vocabulary.uncefact.org/untp/PartyRole#regulator> a untp:PartyRole ;
    rdfs:label "Authority responsible for regulatory oversight" ;
    rdf:value "regulator" .

<https://vocabulary.uncefact.org/untp/PartyRole#remanufacturer> a untp:PartyRole ;
    rdfs:label "Party that remanufactures or refurbishes products" ;
    rdf:value "remanufacturer" .

<https://vocabulary.uncefact.org/untp/PartyRole#retailer> a untp:PartyRole ;
    rdfs:label "Party selling goods to end users" ;
    rdf:value "retailer" .

<https://vocabulary.uncefact.org/untp/PartyRole#serviceProvider> a untp:PartyRole ;
    rdfs:label "Party providing maintenance or servicing" ;
    rdf:value "serviceProvider" .

<https://vocabulary.uncefact.org/untp/ProductIDGranularity#batch> a untp:ProductIDGranularity ;
    rdfs:label "product manufactured batch level ID" ;
    rdf:value "batch" ;
    rdfs:comment "" .

<https://vocabulary.uncefact.org/untp/ProductIDGranularity#item> a untp:ProductIDGranularity ;
    rdfs:label "serialised item level ID" ;
    rdf:value "item" ;
    rdfs:comment "" .

<https://vocabulary.uncefact.org/untp/ProductIDGranularity#model> a untp:ProductIDGranularity ;
    rdfs:label "product model level ID" ;
    rdf:value "model" ;
    rdfs:comment "" .

<https://vocabulary.uncefact.org/untp/ProductStatus#active> a untp:ProductStatus ;
    rdfs:label "Active" ;
    rdf:value "active" ;
    rdfs:comment "Product is in active service or use by the end customer or a downstream manufacturer. Equivalent to GS1 CBV Disp-retail_sold." .

<https://vocabulary.uncefact.org/untp/ProductStatus#consumed> a untp:ProductStatus ;
    rdfs:label "Consumed" ;
    rdf:value "consumed" ;
    rdfs:comment "Product has been consumed as an input to a manufacturing process and no longer exists as a separate item. No direct GS1 CBV equivalent." .

<https://vocabulary.uncefact.org/untp/ProductStatus#disposed> a untp:ProductStatus ;
    rdfs:label "Disposed" ;
    rdf:value "disposed" ;
    rdfs:comment "Product has reached end of life and has been disposed of or destroyed without material recovery. Equivalent to GS1 CBV Disp-disposed and Disp-destroyed." .

<https://vocabulary.uncefact.org/untp/ProductStatus#expired> a untp:ProductStatus ;
    rdfs:label "Expired" ;
    rdf:value "expired" ;
    rdfs:comment "Product has passed its use-by, certification, or regulatory expiration date. Equivalent to GS1 CBV Disp-expired." .

<https://vocabulary.uncefact.org/untp/ProductStatus#inTransit> a untp:ProductStatus ;
    rdfs:label "In Transit" ;
    rdf:value "inTransit" ;
    rdfs:comment "Product has been shipped and is in transit between facilities. Equivalent to GS1 CBV Disp-in_transit." .

<https://vocabulary.uncefact.org/untp/ProductStatus#new> a untp:ProductStatus ;
    rdfs:label "New" ;
    rdf:value "new" ;
    rdfs:comment "Product has been newly manufactured or produced and has not yet entered service. Equivalent to GS1 CBV Disp-active." .

<https://vocabulary.uncefact.org/untp/ProductStatus#recalled> a untp:ProductStatus ;
    rdfs:label "Recalled" ;
    rdf:value "recalled" ;
    rdfs:comment "Product has been withdrawn from the market or service due to a safety, quality, or compliance issue. Equivalent to GS1 CBV Disp-recalled." .

<https://vocabulary.uncefact.org/untp/ProductStatus#recycled> a untp:ProductStatus ;
    rdfs:label "Recycled" ;
    rdf:value "recycled" ;
    rdfs:comment "Product has been processed to recover constituent materials for reuse in new products. No direct GS1 CBV equivalent." .

<https://vocabulary.uncefact.org/untp/ProductStatus#repaired> a untp:ProductStatus ;
    rdfs:label "Repaired" ;
    rdf:value "repaired" ;
    rdfs:comment "Product has been repaired or refurbished to restore functionality and returned to service. Equivalent to GS1 CBV Disp-available (after a repairing step)." .

<https://vocabulary.uncefact.org/untp/RegistryType#accreditation> a untp:RegistryType ;
    rdfs:label "Accreditation" ;
    rdf:value "accreditation" ;
    rdfs:comment "A register of accredited conformity assessment bodies, maintained by a national or regional accreditation authority." .

<https://vocabulary.uncefact.org/untp/RegistryType#business> a untp:RegistryType ;
    rdfs:label "Business" ;
    rdf:value "business" ;
    rdfs:comment "A register of business entities or legal persons, such as a national company register, VAT register, or LEI registry." .

<https://vocabulary.uncefact.org/untp/RegistryType#facility> a untp:RegistryType ;
    rdfs:label "Facility" ;
    rdf:value "facility" ;
    rdfs:comment "A register of facilities or sites, such as a mining cadastre, environmental permit register, or industrial facility directory." .

<https://vocabulary.uncefact.org/untp/RegistryType#land> a untp:RegistryType ;
    rdfs:label "Land" ;
    rdf:value "land" ;
    rdfs:comment "A register of land titles, parcels, or cadastral boundaries, such as a national land registry or territorial cadastre." .

<https://vocabulary.uncefact.org/untp/RegistryType#product> a untp:RegistryType ;
    rdfs:label "Product" ;
    rdf:value "product" ;
    rdfs:comment "A register of products or product classes, such as a national product catalogue or a GS1 GTIN registry." .

<https://vocabulary.uncefact.org/untp/RegistryType#trademark> a untp:RegistryType ;
    rdfs:label "Trademark" ;
    rdf:value "trademark" ;
    rdfs:comment "A register of trademarks, certification marks, or other intellectual property identifiers maintained by a national or international IP office." .

<https://vocabulary.uncefact.org/untp/SchemeAlignmentLevel#exceeds> a untp:SchemeAlignmentLevel ;
    rdfs:label "Exceeds" ;
    rdf:value "exceeds" ;
    rdfs:comment "The scheme profile or criterion goes beyond the requirements of the referenced standard or regulation, imposing stricter thresholds or broader scope." .

<https://vocabulary.uncefact.org/untp/SchemeAlignmentLevel#meets> a untp:SchemeAlignmentLevel ;
    rdfs:label "Meets" ;
    rdf:value "meets" ;
    rdfs:comment "The scheme profile or criterion fully satisfies the requirements of the referenced standard or regulation." .

<https://vocabulary.uncefact.org/untp/SchemeAlignmentLevel#partial> a untp:SchemeAlignmentLevel ;
    rdfs:label "Partially meets" ;
    rdf:value "partial" ;
    rdfs:comment "The scheme profile or criterion addresses some but not all requirements of the referenced standard or regulation." .

<https://vocabulary.uncefact.org/untp/SchemeEndorsementLevel#endorsed_accreditation> a untp:SchemeEndorsementLevel ;
    rdfs:label "Accreditation authority endorsement of scheme suitability" ;
    rdf:value "endorsed_accreditation" ;
    rdfs:comment "Scheme evaluated for suitability by the Global Accreditation Cooperation Incorporated, or by an accreditation body member of the Global Mutual Recognition Arrangement for such scope, or by a Regional Accreditation Cooperation member." .

<https://vocabulary.uncefact.org/untp/SchemeEndorsementLevel#endorsed_benchmarked> a untp:SchemeEndorsementLevel ;
    rdfs:label "Scheme recognition by a benchmarking organisation approved to UNIDO principles and process" ;
    rdf:value "endorsed_benchmarked" ;
    rdfs:comment "Benchmarking of scheme by an organization approved to UNIDO benchmarking principles and process. UNIDO Global Best Practice Framework for Organisations Performing Benchmarking Activities for Certification-related Conformity Assessment Schemes 2026" .

<https://vocabulary.uncefact.org/untp/SchemeEndorsementLevel#endorsed_mandate> a untp:SchemeEndorsementLevel ;
    rdfs:label "Government owned or mandated scheme" ;
    rdf:value "endorsed_mandate" ;
    rdfs:comment "Ownership of scheme or mandate for adoption of scheme by national government or intergovernmental entity." .

<https://vocabulary.uncefact.org/untp/SchemeEndorsementLevel#endorsed_self> a untp:SchemeEndorsementLevel ;
    rdfs:label "Self-declaration by scheme owner" ;
    rdf:value "endorsed_self" ;
    rdfs:comment "Scheme owner self-declaration using the UNTP scheme declaration template" .

untp:activityType a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "activityType" ;
    rdfs:comment "The business activity that this event represents (eg shipping, repair, etc) using a standard classification scheme - eg https://ref.gs1.org/cbv/BizStep. This may be replaced with industry specific vocabularies (ginning, spinning, weaving, dyeing, etc in textiles)" ;
    schema:domainIncludes untp:LifecycleEvent,
        untp:MakeEvent,
        untp:ModifyEvent,
        untp:MoveEvent ;
    schema:rangeIncludes untp:Classification .

untp:address a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "address" ;
    rdfs:comment "The Postal address of the location." ;
    schema:domainIncludes untp:Facility ;
    schema:rangeIncludes untp:Address .

untp:addressCountry a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "addressCountry" ;
    rdfs:comment "The address country as an ISO-3166 two letter country code and name." ;
    schema:domainIncludes untp:Address ;
    schema:rangeIncludes untp:Country .

untp:administeredBy a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "administeredBy" ;
    rdfs:comment "the issuing body of the regulation. For example Australian Government Department of Climate Change, Energy, the Environment and Water" ;
    schema:domainIncludes untp:Regulation ;
    schema:rangeIncludes untp:Party .

untp:aggregationMethod a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "aggregationMethod" ;
    rdfs:comment "Indicates how to aggregate multiple values to report a single performance metric." ;
    schema:domainIncludes untp:PerformanceMetric ;
    schema:rangeIncludes untp:AggregationType .

untp:alignmentLevel a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "alignmentLevel" ;
    rdfs:comment "A level of alignment with the referenced standard (exceeds, meets, partial,..)" ;
    schema:domainIncludes untp:RegulatoryAlignment,
        untp:StandardAlignment ;
    schema:rangeIncludes untp:SchemeAlignmentLevel .

untp:allowedUnit a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "allowedUnit" ;
    rdfs:comment "The allowed units for value reporting against this metric (eg cubic meters)" ;
    schema:domainIncludes untp:PerformanceMetric ;
    schema:rangeIncludes untp:UnitOfMeasure .

untp:applicablePeriod a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "applicablePeriod" ;
    rdfs:comment "The applicable reporting period for this facility record.",
        "The period over which this material consumption is reported" ;
    schema:domainIncludes untp:Claim,
        untp:MaterialUsage ;
    schema:rangeIncludes untp:Period .

untp:assessedFacility a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "assessedFacility" ;
    rdfs:comment "The facility which is the subject of this assessment." ;
    schema:domainIncludes untp:ConformityAssessment ;
    schema:rangeIncludes untp:FacilityVerification .

untp:assessedOrganisation a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "assessedOrganisation" ;
    rdfs:comment "An organisation that is the subject of this assessment." ;
    schema:domainIncludes untp:ConformityAssessment ;
    schema:rangeIncludes untp:Party .

untp:assessedPerformance a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "assessedPerformance" ;
    rdfs:comment "The assessed performance against criteria." ;
    schema:domainIncludes untp:ConformityAssessment ;
    schema:rangeIncludes untp:Performance .

untp:assessedProduct a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "assessedProduct" ;
    rdfs:comment "The product which is the subject of this assessment." ;
    schema:domainIncludes untp:ConformityAssessment ;
    schema:rangeIncludes untp:ProductVerification .

untp:assessmentCriteria a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "assessmentCriteria" ;
    rdfs:comment "The specification against which the assessment is made." ;
    schema:domainIncludes untp:ConformityAssessment ;
    schema:rangeIncludes untp:Criterion .

untp:assessmentDate a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "assessmentDate" ;
    rdfs:comment "The date on which this assessment was made. " ;
    schema:domainIncludes untp:ConformityAssessment ;
    schema:rangeIncludes xsd:date .

untp:assessmentLevel a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "assessmentLevel" ;
    rdfs:comment "Assurance pertaining to assessment (any authority or support for the assessment process)" ;
    schema:domainIncludes untp:ConformityAttestation ;
    schema:rangeIncludes untp:AssessmentLevel .

untp:assessorLevel a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "assessorLevel" ;
    rdfs:comment "Assurance code pertaining to assessor (relation to the object under assessment)" ;
    schema:domainIncludes untp:ConformityAttestation ;
    schema:rangeIncludes untp:AssessorLevel .

untp:attestationType a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "attestationType" ;
    rdfs:comment "The type of criterion (optional or mandatory)." ;
    schema:domainIncludes untp:ConformityAttestation ;
    schema:rangeIncludes untp:AttestationType .

untp:auditableEvidence a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "auditableEvidence" ;
    rdfs:comment "Auditable evidence supporting this assessment such as raw measurements, supporting documents. This is usually private data and would normally be encrypted." ;
    schema:domainIncludes untp:ConformityAttestation ;
    schema:rangeIncludes untp:Link .

untp:authorisation a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "authorisation" ;
    rdfs:comment "The authority under which a conformity claim is issued.  For example a national accreditation authority may authorise a test lab to issue test certificates about a product against a standard.  " ;
    schema:domainIncludes untp:ConformityAttestation ;
    schema:rangeIncludes untp:Endorsement .

untp:batchNumber a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "batchNumber" ;
    rdfs:comment "Identifier of the specific production batch of the product.  Unique within the product class." ;
    schema:domainIncludes untp:Product ;
    schema:rangeIncludes xsd:string .

untp:characteristics a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "characteristics" ;
    rdfs:comment "A set of industry specific product information. " ;
    schema:domainIncludes untp:Product ;
    schema:rangeIncludes untp:Characteristics .

untp:claimDate a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "claimDate" ;
    rdfs:comment "That date on which the claimed performance is applicable." ;
    schema:domainIncludes untp:Claim ;
    schema:rangeIncludes xsd:date .

untp:claimedPerformance a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "claimedPerformance" ;
    rdfs:comment "The claimed performance level " ;
    schema:domainIncludes untp:Claim ;
    schema:rangeIncludes untp:Performance .

untp:code a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "code" ;
    rdfs:comment "The coded value for this score (eg \"AAA\")",
        "classification code within the scheme" ;
    schema:domainIncludes untp:Classification,
        untp:Score ;
    schema:rangeIncludes xsd:string .

untp:conformance a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "conformance" ;
    rdfs:comment "An indicator (true / false) whether the outcome of this assessment is conformant to the requirements defined by the standard or criterion." ;
    schema:domainIncludes untp:ConformityAssessment ;
    schema:rangeIncludes xsd:boolean .

untp:conformityAssessment a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "conformityAssessment" ;
    rdfs:comment "A list of individual assessment made under this attestation. " ;
    schema:domainIncludes untp:ConformityAttestation ;
    schema:rangeIncludes untp:ConformityAssessment .

untp:conformityCertificate a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "conformityCertificate" ;
    rdfs:comment "A reference to the human / printable version of this conformity attestation - typically represented as a PDF document. The document may have more details than are represented in the digital attestation." ;
    schema:domainIncludes untp:ConformityAttestation ;
    schema:rangeIncludes untp:Link .

untp:conformityTopic a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "conformityTopic" ;
    rdfs:comment "A global UN/CEFACT standard conformity topic code. ",
        "The UNTP conformity topic used to categorise this assessment. Should match the topic defined by the scheme criterion.",
        "The conformity topic category for this assessment" ;
    schema:domainIncludes untp:Claim,
        untp:ConformityAssessment,
        untp:Criterion ;
    schema:rangeIncludes untp:ConformityTopic .

untp:conformsTo a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "conformsTo" ;
    rdfs:comment "The name and URI of the vocabulary standard (eg UNTP CVC) that the machine readable version of this sceme conforms to." ;
    schema:domainIncludes untp:ConformityScheme ;
    schema:rangeIncludes untp:Link .

untp:consignmentId a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "consignmentId" ;
    rdfs:comment "The consignment ID related to this movement of products. Ideally this is a resolvable URL but if not available then use a URN notation such as urn:carrier:waybillNumber." ;
    schema:domainIncludes untp:MoveEvent ;
    schema:rangeIncludes xsd:anyURI .

untp:countryCode a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "countryCode" ;
    rdfs:comment "ISO 3166 country code" ;
    schema:domainIncludes untp:Country ;
    schema:rangeIncludes untp:CountryCode .

untp:countryName a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "countryName" ;
    rdfs:comment "Country Name as defined in ISO 3166" ;
    schema:domainIncludes untp:Country ;
    schema:rangeIncludes xsd:string .

untp:countryOfOperation a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "countryOfOperation" ;
    rdfs:comment "The country in which this facility is operating.using ISO-3166 code and name." ;
    schema:domainIncludes untp:Facility ;
    schema:rangeIncludes untp:Country .

untp:countryOfProduction a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "countryOfProduction" ;
    rdfs:comment "The country in which this item was produced / manufactured.using ISO-3166 code and name." ;
    schema:domainIncludes untp:Product ;
    schema:rangeIncludes untp:Country .

untp:credentialSubjectType a rdf:Property ;
    rdfs:label "credentialSubjectType" ;
    rdfs:comment "The expected type of the credentialSubject for this credential class. Used to connect UNTP credential types to the UNTP domain classes that populate the W3C VCDM credentialSubject property, without redefining the W3C property itself." ;
    schema:domainIncludes untp:DigitalConformityCredential,
        untp:DigitalFacilityRecord,
        untp:DigitalIdentityAnchor,
        untp:DigitalProductPassport,
        untp:DigitalTraceabilityEvent ;
    schema:rangeIncludes rdfs:Class .

untp:criterion a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "criterion" ;
    rdfs:comment "A list of criterion that are included in this conformity profile." ;
    schema:domainIncludes untp:ConformityProfile ;
    schema:rangeIncludes untp:Criterion .

untp:criterionScoringFramework a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "criterionScoringFramework" ;
    rdfs:comment "A list of named scoring frameworks that are applied by criterion within this profile. " ;
    schema:domainIncludes untp:ConformityProfile ;
    schema:rangeIncludes untp:ScoringFramework .

untp:definition a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "definition" ;
    rdfs:comment "A description of the meaning of this score.",
        "A rich definition of this classification code.",
        "The rich definition of this conformity topic." ;
    schema:domainIncludes untp:Classification,
        untp:ConformityTopic,
        untp:Score ;
    schema:rangeIncludes xsd:string .

untp:description a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "description" ;
    rdfs:comment "A full text description of the criterion that clearly specifies how compliance is achieved and measured. ",
        "A rich description of this reporting metric.",
        "A rich descrition of this identified entity.  ",
        "Description of the facility including function and other names.",
        "Description of the packaging.",
        "Description of the party including function and other names.",
        "Description of the product.",
        "Description of this attestation.",
        "Description of this conformity assessment ",
        "Description of this conformity claim",
        "Description of this conformity scheme",
        "Description of this criterion",
        "Description of this regulation.",
        "Description of this standard.",
        "The description of this lifecycle event.",
        "The description of this versioned and context specific conformity profile.",
        "The detailed description / supporting information for this image." ;
    schema:domainIncludes untp:Claim,
        untp:ConformityAssessment,
        untp:ConformityAttestation,
        untp:ConformityProfile,
        untp:ConformityScheme,
        untp:Criterion,
        untp:Entity,
        untp:Facility,
        untp:Image,
        untp:LifecycleEvent,
        untp:MakeEvent,
        untp:ModifyEvent,
        untp:MoveEvent,
        untp:Package,
        untp:Party,
        untp:PerformanceMetric,
        untp:Product,
        untp:Regulation,
        untp:ScoringFramework,
        untp:Standard ;
    schema:rangeIncludes xsd:string .

untp:digestMultibase a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "digestMultibase" ;
    rdfs:comment "An optional multi-base encoded digest to ensure the content of the link has not changed. See https://www.w3.org/TR/vc-data-integrity/#resource-integrity for more information.",
        "Used for resource integrity and/or validation of the inline `template`" ;
    schema:domainIncludes untp:Link,
        untp:RenderTemplate2024 ;
    schema:rangeIncludes xsd:string .

untp:dimensions a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "dimensions" ;
    rdfs:comment "The physical dimensions of the product. Not every dimension is relevant to every products.  For example bulk materials may have weight and volume but not length, width, or height.\"weight\":{\"value\":10, \"unit\":\"KGM\"}",
        "dimensions of the packaging" ;
    schema:domainIncludes untp:Package,
        untp:Product ;
    schema:rangeIncludes untp:Dimension .

untp:disposition a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "disposition" ;
    rdfs:comment "The status of the product after the event has happened." ;
    schema:domainIncludes untp:EventProduct ;
    schema:rangeIncludes untp:ProductStatus .

untp:documentation a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "documentation" ;
    rdfs:comment "A web page carrying detailed information about this criterion.",
        "A web page providing full documentation of this scheme.",
        "A web page that describes this entity in detail." ;
    schema:domainIncludes untp:ConformityProfile,
        untp:ConformityScheme,
        untp:Criterion ;
    schema:rangeIncludes xsd:anyURI .

untp:effectiveDate a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "effectiveDate" ;
    rdfs:comment "the date at which the regulation came into effect." ;
    schema:domainIncludes untp:Regulation ;
    schema:rangeIncludes xsd:date .

untp:endDate a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "endDate" ;
    rdfs:comment "The period end date" ;
    schema:domainIncludes untp:Period ;
    schema:rangeIncludes xsd:date .

untp:endorsement a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "endorsement" ;
    rdfs:comment "The endorsement provided to the scheme by an external authority such as a regulator, an accreditaiton authority, or a benchmarking scheme." ;
    schema:domainIncludes untp:ConformityScheme ;
    schema:rangeIncludes untp:Endorsement .

untp:endorsementEvidence a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "endorsementEvidence" ;
    rdfs:comment "The evidence that supports the authority under which the attestation is issued - for an example an accreditation certificate." ;
    schema:domainIncludes untp:Endorsement ;
    schema:rangeIncludes untp:Link .

untp:endorsementLevel a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "endorsementLevel" ;
    rdfs:comment "The scheme assurance type." ;
    schema:domainIncludes untp:ConformityScheme ;
    schema:rangeIncludes untp:SchemeEndorsementLevel .

untp:establishedDate a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "establishedDate" ;
    rdfs:comment "The date when this scheme was first established.  " ;
    schema:domainIncludes untp:ConformityScheme ;
    schema:rangeIncludes xsd:date .

untp:eventDate a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "eventDate" ;
    rdfs:comment "The date and time at which this lifecycle event occurs. use 00:00 for time if only a date is required." ;
    schema:domainIncludes untp:LifecycleEvent,
        untp:MakeEvent,
        untp:ModifyEvent,
        untp:MoveEvent ;
    schema:rangeIncludes xsd:datetime .

untp:evidence a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "evidence" ;
    rdfs:comment "A URI pointing to the evidence supporting the claim. SHOULD be a URL to a UNTP Digital Conformity Credential (DCC)",
        "Evidence to support this specific assessment." ;
    schema:domainIncludes untp:Claim,
        untp:ConformityAssessment ;
    schema:rangeIncludes untp:Link .

untp:expiryDate a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "expiryDate" ;
    rdfs:comment "The date at which this product is no longer fit for use. Typically used for a food product use-by date but may also represent the usable life of any product." ;
    schema:domainIncludes untp:Product ;
    schema:rangeIncludes xsd:date .

untp:extendsModel a rdf:Property ;
    rdfs:label "extendsModel" ;
    rdfs:comment "Indicates that this UNTP class reuses and extends a class defined in an external vocabulary (e.g. W3C VCDM, schema.org). The external class defines the envelope or base properties; UNTP defines only the extensions. This annotation enables human-readable renderings to display or link to the inherited properties without redefining them." ;
    schema:domainIncludes untp:Address,
        untp:VerifiableCredential ;
    schema:rangeIncludes rdfs:Class .

untp:facility a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "facility" ;
    rdfs:comment "The facility which is the subject of this assessment" ;
    schema:domainIncludes untp:FacilityVerification ;
    schema:rangeIncludes untp:Facility .

untp:facilityAlsoKnownAs a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "facilityAlsoKnownAs" ;
    rdfs:comment "An optional list of other registered identifiers for this facility - eg GLNs or other schemes." ;
    schema:domainIncludes untp:Facility ;
    schema:rangeIncludes untp:Facility .

untp:fromFacility a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "fromFacility" ;
    rdfs:comment "The source facility for this movement / shipment of products" ;
    schema:domainIncludes untp:MoveEvent ;
    schema:rangeIncludes untp:Facility .

untp:geoBoundary a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "geoBoundary" ;
    rdfs:comment "The list of ordered coordinates that define a closed area polygon as a location boundary. The first and last coordinates in the array must match - thereby defining a closed boundary." ;
    schema:domainIncludes untp:Location ;
    schema:rangeIncludes untp:Coordinate .

untp:geoLocation a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "geoLocation" ;
    rdfs:comment "The geolocation of this sensor data recording event.",
        "The latitude and longitude coordinates that best represent the specified location. " ;
    schema:domainIncludes untp:Location,
        untp:SensorData ;
    schema:rangeIncludes untp:Coordinate .

untp:geographicScope a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "geographicScope" ;
    rdfs:comment "The geographic scope of this scheme as a list of ISO-3166 countries, regions, or code=001, name=Worldwide to indicate global coverage." ;
    schema:domainIncludes untp:ConformityScheme ;
    schema:rangeIncludes untp:Classification .

untp:hazardous a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "hazardous" ;
    rdfs:comment "Indicates whether this material is hazardous. If true then the materialSafetyInformation property must be present" ;
    schema:domainIncludes untp:Material ;
    schema:rangeIncludes xsd:boolean .

untp:height a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "height" ;
    rdfs:comment "The height of the product or packaging. eg {\"value\":220, \"unit\":\"MMT\"}" ;
    schema:domainIncludes untp:Dimension ;
    schema:rangeIncludes untp:Measure .

untp:id a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "id" ;
    rdfs:comment "Globally unique ID for this lifecycle event. Should be a URI. Can be a UUID.",
        "Globally unique identifier of this assessment. Typically represented as a URI AssessmentBody/Assessment URI or a UUID",
        "Globally unique identifier of this attestation. Typically represented as a URI AssessmentBody/CertificateID URI or a UUID",
        "Globally unique identifier of this claim. Typically represented as a URI companyURL/claimID URI or a UUID",
        "Globally unique identifier of this conformity criterion. Typically represented as a URI SchemeOwner/CriterionID URI",
        "Globally unique identifier of this conformity scheme. Typically represented as a URI SchemeOwner/SchemeName URI",
        "Globally unique identifier of this context specific conformity profile. Typically represented as a URI SchemeOwner/profileID URI",
        "Globally unique identifier of this facility. Typically represented as a URI identifierScheme/Identifier URI",
        "Globally unique identifier of this party. Typically represented as a URI identifierScheme/Identifier URI",
        "Globally unique identifier of this product. Typically represented as a URI identifierScheme/Identifier URI or, if self-issued, as a did.",
        "Globally unique identifier of this reporting metric. ",
        "Globally unique identifier of this standard. Typically represented as a URI government/regulation URI",
        "Globally unique identifier of this standard. Typically represented as a URI issuer/standard URI",
        "The DID that is controlled by the registered member and is linked to the registeredID through this Identity Anchor credential",
        "The URI of this identifier scheme",
        "The W3C DID of the issuer - should be a did:web or did:webvh",
        "The globally unique identifier of this entity. ",
        "The unique identifier for this conformity topic",
        "optional identifier of this status list entry." ;
    schema:domainIncludes untp:BitstringStatusListEntry,
        untp:Claim,
        untp:ConformityAssessment,
        untp:ConformityAttestation,
        untp:ConformityProfile,
        untp:ConformityScheme,
        untp:ConformityTopic,
        untp:CredentialIssuer,
        untp:Criterion,
        untp:Entity,
        untp:Facility,
        untp:IdentifierScheme,
        untp:LifecycleEvent,
        untp:MakeEvent,
        untp:ModifyEvent,
        untp:MoveEvent,
        untp:Party,
        untp:PerformanceMetric,
        untp:Product,
        untp:RegisteredIdentity,
        untp:Regulation,
        untp:Standard ;
    schema:rangeIncludes xsd:anyURI .

untp:idGranularity a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "idGranularity" ;
    rdfs:comment "The identification granularity for this product (item, batch, model)" ;
    schema:domainIncludes untp:Product ;
    schema:rangeIncludes untp:ProductIDGranularity .

untp:idScheme a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "idScheme" ;
    rdfs:comment "The ID scheme of the facility. eg a GS1 GLN or a National land registry scheme. If self issued then use the party ID of the facility owner. ",
        "The identifier scheme for this product.  Eg a GS1 GTIN or an AU Livestock NLIS, or similar. If self issued then use the party ID of the issuer.  ",
        "The identifier scheme for this registered entity ID.",
        "The identifier scheme of the party.  Typically a national business register or a global scheme such as GLEIF. " ;
    schema:domainIncludes untp:Facility,
        untp:Party,
        untp:Product,
        untp:RegisteredIdentity ;
    schema:rangeIncludes untp:IdentifierScheme .

untp:idVerifiedByCAB a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "idVerifiedByCAB" ;
    rdfs:comment "Indicates whether the conformity assessment body has verified the identity of the facility which is the subject of the assessment.",
        "Indicates whether the conformity assessment body has verified the identity product that is the subject of the assessment." ;
    schema:domainIncludes untp:FacilityVerification,
        untp:ProductVerification ;
    schema:rangeIncludes xsd:boolean .

untp:imageData a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "imageData" ;
    rdfs:comment "The image data encoded as a base64 string." ;
    schema:domainIncludes untp:Image ;
    schema:rangeIncludes xsd:string .

untp:improvementDirection a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "improvementDirection" ;
    rdfs:comment "Indicator of whether conforming performance is greater than or less than the defined threshold." ;
    schema:domainIncludes untp:PerformanceMetric ;
    schema:rangeIncludes untp:ImprovementIndicator .

untp:includedProfile a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "includedProfile" ;
    rdfs:comment "The list of versioned conformity profiles included in this scheme" ;
    schema:domainIncludes untp:ConformityScheme ;
    schema:rangeIncludes untp:ConformityProfile .

untp:industryCategory a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "industryCategory" ;
    rdfs:comment "The industry categories for this organisation.  Recommend use of UNCPC as the category scheme. for example - unstats.un.org/isic/1030" ;
    schema:domainIncludes untp:Party ;
    schema:rangeIncludes untp:Classification .

untp:industryScope a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "industryScope" ;
    rdfs:comment "A list of UN ISIC code & name indicating the industry scope for this scheme.  " ;
    schema:domainIncludes untp:ConformityScheme ;
    schema:rangeIncludes untp:Classification .

untp:inputProduct a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "inputProduct" ;
    rdfs:comment "An array of input products and quantities for this production or manufacturing process" ;
    schema:domainIncludes untp:MakeEvent ;
    schema:rangeIncludes untp:EventProduct .

untp:issueDate a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "issueDate" ;
    rdfs:comment "The date when the standard was issued." ;
    schema:domainIncludes untp:Standard ;
    schema:rangeIncludes xsd:date .

untp:issuedToParty a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "issuedToParty" ;
    rdfs:comment "The party to whom the conformity attestation was issued." ;
    schema:domainIncludes untp:ConformityAttestation ;
    schema:rangeIncludes untp:Party .

untp:issuerAlsoKnownAs a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "issuerAlsoKnownAs" ;
    rdfs:comment "An optional list of other registered identifiers for this credential issuer " ;
    schema:domainIncludes untp:CredentialIssuer ;
    schema:rangeIncludes untp:Party .

untp:issuingAuthority a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "issuingAuthority" ;
    rdfs:comment "The competent authority that issued the accreditation." ;
    schema:domainIncludes untp:Endorsement ;
    schema:rangeIncludes untp:Party .

untp:issuingParty a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "issuingParty" ;
    rdfs:comment "The party that issued the standard " ;
    schema:domainIncludes untp:Standard ;
    schema:rangeIncludes untp:Party .

untp:issuingSoftware a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "issuingSoftware" ;
    rdfs:comment "Optional metadata identifying the software product (and its vendor) that issued this credential." ;
    schema:domainIncludes untp:DigitalConformityCredential,
        untp:DigitalFacilityRecord,
        untp:DigitalIdentityAnchor,
        untp:DigitalProductPassport,
        untp:DigitalTraceabilityEvent ;
    schema:rangeIncludes untp:IssuingSoftware .

untp:itemNumber a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "itemNumber" ;
    rdfs:comment "A number or code representing a specific serialised item of the product. Unique within product class." ;
    schema:domainIncludes untp:Product ;
    schema:rangeIncludes xsd:string .

untp:jurisdictionCountry a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "jurisdictionCountry" ;
    rdfs:comment "The legal jurisdiction (country) under which the regulation is issued." ;
    schema:domainIncludes untp:Regulation ;
    schema:rangeIncludes untp:Country .

untp:latitude a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "latitude" ;
    rdfs:comment "latitude: Angular distance north or south of the equator, expressed in decimal degrees.Valid range: −90.0 to +90.0." ;
    schema:domainIncludes untp:Coordinate ;
    schema:rangeIncludes xsd:double .

untp:length a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "length" ;
    rdfs:comment "The length of the product or packaging eg {\"value\":840, \"unit\":\"MMT\"}" ;
    schema:domainIncludes untp:Dimension ;
    schema:rangeIncludes untp:Measure .

untp:licenseType a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "licenseType" ;
    rdfs:comment "Descriptive name and URL link to the license conditions associated with this scheme." ;
    schema:domainIncludes untp:ConformityScheme ;
    schema:rangeIncludes untp:LicenseType .

untp:linkName a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "linkName" ;
    rdfs:comment "Display name for this link." ;
    schema:domainIncludes untp:Link ;
    schema:rangeIncludes xsd:string .

untp:linkType a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "linkType" ;
    rdfs:comment "The type of the target resource - drawn from a controlled vocabulary " ;
    schema:domainIncludes untp:Link ;
    schema:rangeIncludes xsd:string .

untp:linkURL a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "linkURL" ;
    rdfs:comment "The URL of the target resource.  " ;
    schema:domainIncludes untp:Link ;
    schema:rangeIncludes xsd:anyURI .

untp:locationInformation a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "locationInformation" ;
    rdfs:comment "Geo-location information for this facility as a resolvable geographic area (a Plus Code), and/or a geo-located point (latitude / longitude), and/or a defined boundary (GeoJSON Polygon)." ;
    schema:domainIncludes untp:Facility ;
    schema:rangeIncludes untp:Location .

untp:longitude a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "longitude" ;
    rdfs:comment "longitude: Angular distance east or west of the Prime Meridian, expressed in decimal degrees.Valid range: −180.0 to +180.0." ;
    schema:domainIncludes untp:Coordinate ;
    schema:rangeIncludes xsd:double .

untp:lowerTolerance a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "lowerTolerance" ;
    rdfs:comment "The lower tolerance associated with this measure expressed in the same units as the measure.  For example value=10, lowerTolerance=0.1, unit=KGM would mean that this measure is 10kg - 0.1kg" ;
    schema:domainIncludes untp:Measure ;
    schema:rangeIncludes xsd:double .

untp:madeAtFacility a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "madeAtFacility" ;
    rdfs:comment "The facility at which this production / manufacturing event happens." ;
    schema:domainIncludes untp:MakeEvent ;
    schema:rangeIncludes untp:Facility .

untp:mass a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "mass" ;
    rdfs:comment "The mass of the material component." ;
    schema:domainIncludes untp:Material ;
    schema:rangeIncludes untp:Measure .

untp:massFraction a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "massFraction" ;
    rdfs:comment "The mass fraction as a decimal of the product (or facility reporting period)  represented by this material. " ;
    schema:domainIncludes untp:Material ;
    schema:rangeIncludes xsd:double .

untp:materialConsumed a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "materialConsumed" ;
    rdfs:comment "An list of materials consumed during the usage period. " ;
    schema:domainIncludes untp:MaterialUsage ;
    schema:rangeIncludes untp:Material .

untp:materialProvenance a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "materialProvenance" ;
    rdfs:comment "A list of materials provenance objects providing details on the origin and mass fraction of materials of the product or batch." ;
    schema:domainIncludes untp:Product ;
    schema:rangeIncludes untp:Material .

untp:materialSafetyInformation a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "materialSafetyInformation" ;
    rdfs:comment "Reference to further information about safe handling of this hazardous material (for example a link to a material safety data sheet)" ;
    schema:domainIncludes untp:Material ;
    schema:rangeIncludes untp:Link .

untp:materialType a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "materialType" ;
    rdfs:comment "The type of this material - as a value drawn from a controlled vocabulary eg from UN Framework Classification for Resources (UNFC)." ;
    schema:domainIncludes untp:Material ;
    schema:rangeIncludes untp:Classification .

untp:materialUsage a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "materialUsage" ;
    rdfs:comment "The type and provenance of materials consumed by the facility during the reporting period. " ;
    schema:domainIncludes untp:Facility ;
    schema:rangeIncludes untp:MaterialUsage .

untp:materialUsed a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "materialUsed" ;
    rdfs:comment "materials used for the packaging." ;
    schema:domainIncludes untp:Package ;
    schema:rangeIncludes untp:Material .

untp:measure a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "measure" ;
    rdfs:comment "The measured performance value",
        "The value measured by this sensor measurement event." ;
    schema:domainIncludes untp:Performance,
        untp:SensorData ;
    schema:rangeIncludes untp:Measure .

untp:mediaQuery a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "mediaQuery" ;
    rdfs:comment "Media query as defined in https://www.w3.org/TR/mediaqueries-4/" ;
    schema:domainIncludes untp:RenderTemplate2024 ;
    schema:rangeIncludes xsd:string .

untp:mediaType a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "mediaType" ;
    rdfs:comment "The media type of the target resource.",
        "The media type of this image (eg image/png)",
        "media type of the rendered output (eg text/html)" ;
    schema:domainIncludes untp:Image,
        untp:Link,
        untp:RenderTemplate2024 ;
    schema:rangeIncludes xsd:string .

untp:metric a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "metric" ;
    rdfs:comment "The metric (eg material emissions intensity CO2e/Kg or percentage of young workers) that is measured.",
        "The type of measurement recorded in this sensor data event." ;
    schema:domainIncludes untp:Performance,
        untp:SensorData ;
    schema:rangeIncludes untp:PerformanceMetric .

untp:modelNumber a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "modelNumber" ;
    rdfs:comment "Where available, the model number (for manufactured products) or material identification (for bulk materials)" ;
    schema:domainIncludes untp:Product ;
    schema:rangeIncludes xsd:string .

untp:modifiedAtFacility a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "modifiedAtFacility" ;
    rdfs:comment "The facility at which this intervention event happens." ;
    schema:domainIncludes untp:ModifyEvent ;
    schema:rangeIncludes untp:Facility .

untp:modifiedProduct a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "modifiedProduct" ;
    rdfs:comment "An array of products and quantities for this intervention (repair, inspection, etc)" ;
    schema:domainIncludes untp:ModifyEvent ;
    schema:rangeIncludes untp:EventProduct .

untp:movedProduct a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "movedProduct" ;
    rdfs:comment "An array of products and quantities for this movement / shipment process" ;
    schema:domainIncludes untp:MoveEvent ;
    schema:rangeIncludes untp:EventProduct .

untp:name a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:comment "A human readable name for this metric (for example \"water usage per Kg of material\")",
        "A name for this scoring framework.  Must be unique within a scheme.",
        "Human facing display name for selection",
        "Legal registered name of this party.",
        "Name for this standard",
        "Name of the classification represented by the code",
        "Name of this assessment - typically similar or the same as the referenced criterion name.",
        "Name of this attestation - typically the title of the certificate.",
        "Name of this claim - typically similar or the same as the referenced criterion name.",
        "Name of this conformity profile as defined by the scheme owner.",
        "Name of this criterion as defined by the scheme owner.",
        "Name of this facility as defined the location register.",
        "Name of this material (eg \"Egyptian Cotton\")",
        "Name of this regulation as defined by the regulator.",
        "Name of this scheme as defined by the scheme owner.",
        "The human readable name for this conformity topic.",
        "The name for this lifecycle event ",
        "The name of the accreditation.",
        "The name of the identifier scheme. ",
        "The name of the issuer person or organisation",
        "The name of this entity.",
        "The product name as known to the market.",
        "the display name for this image" ;
    schema:domainIncludes untp:Claim,
        untp:Classification,
        untp:ConformityAssessment,
        untp:ConformityAttestation,
        untp:ConformityProfile,
        untp:ConformityScheme,
        untp:ConformityTopic,
        untp:CredentialIssuer,
        untp:Criterion,
        untp:Endorsement,
        untp:Entity,
        untp:Facility,
        untp:IdentifierScheme,
        untp:Image,
        untp:LifecycleEvent,
        untp:MakeEvent,
        untp:Material,
        untp:ModifyEvent,
        untp:MoveEvent,
        untp:Party,
        untp:PerformanceMetric,
        untp:Product,
        untp:Regulation,
        untp:RenderTemplate2024,
        untp:ScoringFramework,
        untp:Standard ;
    schema:rangeIncludes xsd:string .

untp:organisationWebsite a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "organisationWebsite" ;
    rdfs:comment "Website for this organisation" ;
    schema:domainIncludes untp:Party ;
    schema:rangeIncludes xsd:anyURI .

untp:originCountry a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "originCountry" ;
    rdfs:comment "A ISO 3166-1 code representing the country of origin of the component or ingredient." ;
    schema:domainIncludes untp:Material ;
    schema:rangeIncludes untp:Country .

untp:outputProduct a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "outputProduct" ;
    rdfs:comment "An array of output products and quantities for this produciton or manufacturing process" ;
    schema:domainIncludes untp:MakeEvent ;
    schema:rangeIncludes untp:EventProduct .

untp:owner a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "owner" ;
    rdfs:comment "The party that is the owner / maintainer of this conformity scheme." ;
    schema:domainIncludes untp:ConformityScheme ;
    schema:rangeIncludes untp:Party .

untp:packageLabel a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "packageLabel" ;
    rdfs:comment "An array of package labels that may appear on the packaging together with their meaning. Use for small images that represent certification marks or regulatory requirements. Large images should be linked as evidence to claims." ;
    schema:domainIncludes untp:Package ;
    schema:rangeIncludes untp:Image .

untp:packaging a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "packaging" ;
    rdfs:comment "The packaging for this product." ;
    schema:domainIncludes untp:Product ;
    schema:rangeIncludes untp:Package .

untp:party a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "party" ;
    rdfs:comment "The party that has the specified role." ;
    schema:domainIncludes untp:PartyRole ;
    schema:rangeIncludes untp:Party .

untp:partyAddress a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "partyAddress" ;
    rdfs:comment "The address of the party" ;
    schema:domainIncludes untp:Party ;
    schema:rangeIncludes untp:Address .

untp:partyAlsoKnownAs a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "partyAlsoKnownAs" ;
    rdfs:comment "An optional list of other registered identifiers for this organisation. For example DUNS, GLN, LEI, etc" ;
    schema:domainIncludes untp:Party ;
    schema:rangeIncludes untp:Party .

untp:performanceClaim a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "performanceClaim" ;
    rdfs:comment "A list of performance claims (eg deforestation status) for this facility.",
        "A list of performance claims (eg emissions intensity) for this product.",
        "conformity claims made about the packaging." ;
    schema:domainIncludes untp:Facility,
        untp:Package,
        untp:Product ;
    schema:rangeIncludes untp:Claim .

untp:periodInformation a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "periodInformation" ;
    rdfs:comment "Additional information relevant to this reporting period" ;
    schema:domainIncludes untp:Period ;
    schema:rangeIncludes xsd:string .

untp:plusCode a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "plusCode" ;
    rdfs:comment "An open location code (https://maps.google.com/pluscodes/) representing this geographic location or region. Open location codes can represent any sized area from a point to a large region and are easily resolved to a visual map location. " ;
    schema:domainIncludes untp:Location ;
    schema:rangeIncludes xsd:anyURI .

untp:processCategory a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "processCategory" ;
    rdfs:comment "The industrial or production processes performed by this facility. Example unstats.un.org/isic/1030." ;
    schema:domainIncludes untp:Facility ;
    schema:rangeIncludes untp:Classification .

untp:producedAtFacility a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "producedAtFacility" ;
    rdfs:comment "The Facility where the product batch was produced / manufactured." ;
    schema:domainIncludes untp:Product ;
    schema:rangeIncludes untp:Facility .

untp:product a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "product" ;
    rdfs:comment "The product item / model / batch subject to this lifecycle event.",
        "The product, serial or batch that is the subject of this assessment" ;
    schema:domainIncludes untp:EventProduct,
        untp:ProductVerification ;
    schema:rangeIncludes untp:Product .

untp:productCategory a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "productCategory" ;
    rdfs:comment "A code representing the product's class, typically using the UN CPC (United Nations Central Product Classification) https://unstats.un.org/unsd/classifications/Econ/cpc" ;
    schema:domainIncludes untp:Product ;
    schema:rangeIncludes untp:Classification .

untp:productImage a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "productImage" ;
    rdfs:comment "Reference information (location, type, name) of an image of the product." ;
    schema:domainIncludes untp:Product ;
    schema:rangeIncludes untp:Link .

untp:productLabel a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "productLabel" ;
    rdfs:comment "An array of labels that may appear on the product such as certification marks or regulatory labels." ;
    schema:domainIncludes untp:Product ;
    schema:rangeIncludes untp:Image .

untp:productionDate a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "productionDate" ;
    rdfs:comment "The ISO 8601 date on which the product batch or individual serialised item was manufactured." ;
    schema:domainIncludes untp:Product ;
    schema:rangeIncludes xsd:date .

untp:profileScore a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "profileScore" ;
    rdfs:comment "The overall performance against a scheme level performance measurement framework for the referenced profile or scheme." ;
    schema:domainIncludes untp:ConformityAttestation ;
    schema:rangeIncludes untp:Score .

untp:publicInformation a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "publicInformation" ;
    rdfs:comment "A link to further information about the registered entity on the authoritative registrar site." ;
    schema:domainIncludes untp:RegisteredIdentity ;
    schema:rangeIncludes xsd:anyURI .

untp:quantity a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "quantity" ;
    rdfs:comment "The quantity of product subject to this lifecycle event.  Not needed for serialised items." ;
    schema:domainIncludes untp:EventProduct ;
    schema:rangeIncludes untp:Measure .

untp:rank a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "rank" ;
    rdfs:comment "The ranking of this score within the scoring framework - using an integer where \"1\" is the highest rank." ;
    schema:domainIncludes untp:Score ;
    schema:rangeIncludes xsd:integer .

untp:rawData a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "rawData" ;
    rdfs:comment "Link to raw data file associated with this sensor reading (eg an image)." ;
    schema:domainIncludes untp:SensorData ;
    schema:rangeIncludes untp:Link .

untp:recycledMassFraction a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "recycledMassFraction" ;
    rdfs:comment "Mass fraction of this material that is recycled (eg 50% recycled Lithium)" ;
    schema:domainIncludes untp:Material ;
    schema:rangeIncludes xsd:double .

untp:referenceCriteria a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "referenceCriteria" ;
    rdfs:comment "The criterion against which the claim is made." ;
    schema:domainIncludes untp:Claim ;
    schema:rangeIncludes untp:Criterion .

untp:referenceProfile a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "referenceProfile" ;
    rdfs:comment "The specific versioned conformity profile (comprising a set of versioned criteria) against which this conformity attestation is made." ;
    schema:domainIncludes untp:ConformityAttestation ;
    schema:rangeIncludes untp:ConformityProfile .

untp:referenceRegulation a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "referenceRegulation" ;
    rdfs:comment "List of references to regulation to which conformity is claimed claimed for this product",
        "The reference to the regulation that defines the assessment criteria" ;
    schema:domainIncludes untp:Claim,
        untp:ConformityAssessment ;
    schema:rangeIncludes untp:Regulation .

untp:referenceScheme a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "referenceScheme" ;
    rdfs:comment "The conformity scheme under which this attestation is made." ;
    schema:domainIncludes untp:ConformityAttestation ;
    schema:rangeIncludes untp:ConformityScheme .

untp:referenceStandard a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "referenceStandard" ;
    rdfs:comment "List of references to standards to which conformity is claimed claimed for this product",
        "The reference to the standard that defines the specification / criteria" ;
    schema:domainIncludes untp:Claim,
        untp:ConformityAssessment ;
    schema:rangeIncludes untp:Standard .

untp:registerType a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "registerType" ;
    rdfs:comment "The thematic purpose of the register - organisations, facilities, products, trademarks, etc" ;
    schema:domainIncludes untp:RegisteredIdentity ;
    schema:rangeIncludes untp:RegistryType .

untp:registeredDate a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "registeredDate" ;
    rdfs:comment "The date on which this identity was first registered with the registrar." ;
    schema:domainIncludes untp:RegisteredIdentity ;
    schema:rangeIncludes xsd:date .

untp:registeredId a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "registeredId" ;
    rdfs:comment "The registration number (alphanumeric) of the Party within the register. Unique within the register.",
        "The registration number (alphanumeric) of the entity within the register. Unique within the register.",
        "The registration number (alphanumeric) of the facility within the identifier scheme. Unique within the register." ;
    schema:domainIncludes untp:Facility,
        untp:Party,
        untp:RegisteredIdentity ;
    schema:rangeIncludes xsd:string .

untp:registeredName a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "registeredName" ;
    rdfs:comment "The registered name of the entity within the identifier scheme.  Examples: product - EV battery 300Ah, Party - Sample Company Pty Ltd,  Facility - Green Acres battery factory " ;
    schema:domainIncludes untp:RegisteredIdentity ;
    schema:rangeIncludes xsd:string .

untp:registrar a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "registrar" ;
    rdfs:comment "The registrar party that operates the register." ;
    schema:domainIncludes untp:RegisteredIdentity ;
    schema:rangeIncludes untp:Party .

untp:registrationCountry a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "registrationCountry" ;
    rdfs:comment "the country in which this organisation is registered - using ISO-3166 code and name." ;
    schema:domainIncludes untp:Party ;
    schema:rangeIncludes untp:Country .

untp:registrationScope a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "registrationScope" ;
    rdfs:comment "List of URIs that represent the roles or scopes of membership. For example [\"https://abr.business.gov.au/Help/EntityTypeDescription?Id=19\"]" ;
    schema:domainIncludes untp:RegisteredIdentity ;
    schema:rangeIncludes xsd:anyURI .

untp:regulation a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "regulation" ;
    rdfs:comment "The regulation against which this alignment assessment is made." ;
    schema:domainIncludes untp:RegulatoryAlignment ;
    schema:rangeIncludes untp:Regulation .

untp:regulatoryAlignment a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "regulatoryAlignment" ;
    rdfs:comment "A list of regulations or legally binding conventions referenced by this conformity profile and against which some level of compliance can be inferred for subjects that pass an assessment.  " ;
    schema:domainIncludes untp:ConformityProfile ;
    schema:rangeIncludes untp:RegulatoryAlignment .

untp:relatedDocument a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "relatedDocument" ;
    rdfs:comment "A list of links to documentary evidence that supports this event. ",
        "A list of links to documents providing additional facility information. Documents that support a conformity claim (e.g. permits or certificates) SHOULD be referenced as claim evidence rather than here.",
        "A list of links to documents providing additional product information. Documents that support a conformity claim (e.g. permits or certificates) SHOULD be referenced as claim evidence rather than here." ;
    schema:domainIncludes untp:Facility,
        untp:LifecycleEvent,
        untp:MakeEvent,
        untp:ModifyEvent,
        untp:MoveEvent,
        untp:Product ;
    schema:rangeIncludes untp:Link .

untp:relatedParty a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "relatedParty" ;
    rdfs:comment "A list of parties with a defined relationship to this product",
        "A list of parties with a specified role relationship to this facility ",
        "Any related parties and their roles involved in this event (eg the carrier for a shipment event)" ;
    schema:domainIncludes untp:Facility,
        untp:LifecycleEvent,
        untp:MakeEvent,
        untp:ModifyEvent,
        untp:MoveEvent,
        untp:Product ;
    schema:rangeIncludes untp:PartyRole .

untp:requiredPerformance a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "requiredPerformance" ;
    rdfs:comment "The required performance level as one or more score and/or a metric that represents compliance defined by the criteria" ;
    schema:domainIncludes untp:Criterion ;
    schema:rangeIncludes untp:Performance .

untp:role a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "role" ;
    rdfs:comment "The role played by the party in this relationship" ;
    schema:domainIncludes untp:PartyRole ;
    schema:rangeIncludes untp:PartyRole .

untp:scheme a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "scheme" ;
    rdfs:comment "The conformity scheme under which this versioned profile is maintained." ;
    schema:domainIncludes untp:ConformityProfile ;
    schema:rangeIncludes untp:ConformityScheme .

untp:schemeId a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "schemeId" ;
    rdfs:comment "Classification scheme ID" ;
    schema:domainIncludes untp:Classification ;
    schema:rangeIncludes xsd:anyURI .

untp:schemeName a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "schemeName" ;
    rdfs:comment "The name of the classification scheme" ;
    schema:domainIncludes untp:Classification ;
    schema:rangeIncludes xsd:string .

untp:schemeScoringFramework a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "schemeScoringFramework" ;
    rdfs:comment "The scheme level overall scoring framework that represents the achievement levels (AA, A, B etc) that maybe be awarded to the subject of an independent assessment under the scheme." ;
    schema:domainIncludes untp:ConformityScheme ;
    schema:rangeIncludes untp:ScoringFramework .

untp:scope a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "scope" ;
    rdfs:comment "A set of classification codes that may be used to categorize the applicability of this criteria - for example industry sector, jurisdiction or commodity type - based on a formal vocabulary." ;
    schema:domainIncludes untp:ConformityProfile ;
    schema:rangeIncludes untp:Classification .

untp:score a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "score" ;
    rdfs:comment "A list of scores and ranks associated with this scoring framework.",
        "A performance score (eg \"AA\") drawn from a scoring framework defined by the scheme or criterion." ;
    schema:domainIncludes untp:Performance,
        untp:ScoringFramework ;
    schema:rangeIncludes untp:Score .

untp:sensor a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "sensor" ;
    rdfs:comment "The sensor device used for this sensor measurement" ;
    schema:domainIncludes untp:SensorData ;
    schema:rangeIncludes untp:Product .

untp:sensorData a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "sensorData" ;
    rdfs:comment "A sensor data set associated with this lifecycle event." ;
    schema:domainIncludes untp:LifecycleEvent,
        untp:MakeEvent,
        untp:ModifyEvent,
        untp:MoveEvent ;
    schema:rangeIncludes untp:SensorData .

untp:specifiedCondition a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "specifiedCondition" ;
    rdfs:comment "A list of specific conditions that constrain this conformity assessment. For example a specific jurisdiction, material type, or test method." ;
    schema:domainIncludes untp:ConformityAssessment ;
    schema:rangeIncludes xsd:string .

untp:standard a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "standard" ;
    rdfs:comment "The standard against which this alignment assessment is made." ;
    schema:domainIncludes untp:StandardAlignment ;
    schema:rangeIncludes untp:Standard .

untp:standardAlignment a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "standardAlignment" ;
    rdfs:comment "A list of voluntary standards referenced by this conformity profile and against which some level of compliance can be inferred for subjects that pass an assessment.  " ;
    schema:domainIncludes untp:ConformityProfile ;
    schema:rangeIncludes untp:StandardAlignment .

untp:startDate a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "startDate" ;
    rdfs:comment "The period start date" ;
    schema:domainIncludes untp:Period ;
    schema:rangeIncludes xsd:date .

untp:status a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "status" ;
    rdfs:comment "The lifecycle status of this criterion. ",
        "The status of this conformity profile (draft, active, deprecated)" ;
    schema:domainIncludes untp:ConformityProfile,
        untp:Criterion ;
    schema:rangeIncludes untp:CriterionStatus .

untp:statusListCredential a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "statusListCredential" ;
    rdfs:comment "The statusListCredential property MUST be a URL to a verifiable credential. When the URL is dereferenced, the resulting verifiable credential MUST have type property that includes the BitstringStatusListCredential value." ;
    schema:domainIncludes untp:BitstringStatusListEntry ;
    schema:rangeIncludes xsd:anyURI .

untp:statusListIndex a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "statusListIndex" ;
    rdfs:comment "	The statusListIndex property MUST be an arbitrary size integer greater than or equal to 0, expressed as a string in base 10. The value identifies the position of the status of the verifiable credential." ;
    schema:domainIncludes untp:BitstringStatusListEntry ;
    schema:rangeIncludes xsd:integer .

untp:statusPurpose a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "statusPurpose" ;
    rdfs:comment "Status purpose drawn from a standard list but extensible as per w3c bitstring status list specification." ;
    schema:domainIncludes untp:BitstringStatusListEntry ;
    schema:rangeIncludes untp:CredentialStatus .

untp:subjectType a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "subjectType" ;
    rdfs:comment "The type of the subject of assessments made under this conformity profile (eg product, facility, organisation)" ;
    schema:domainIncludes untp:ConformityProfile ;
    schema:rangeIncludes untp:AssessmentSubjectType .

untp:symbol a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "symbol" ;
    rdfs:comment "Based 64 encoded binary used to represent a visual symbol for a given material. " ;
    schema:domainIncludes untp:Material ;
    schema:rangeIncludes untp:Image .

untp:tag a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "tag" ;
    rdfs:comment "A set of tags that can be used by the scheme owner to be able to filter or group criterion in a large vocabulary for specific use cases." ;
    schema:domainIncludes untp:Criterion ;
    schema:rangeIncludes xsd:string .

untp:template a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "template" ;
    rdfs:comment "An inline template field for use cases where remote retrieval of a render method is suboptimal" ;
    schema:domainIncludes untp:RenderTemplate2024 ;
    schema:rangeIncludes xsd:string .

untp:toFacility a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "toFacility" ;
    rdfs:comment "The destination facility for this movement / shipment of products" ;
    schema:domainIncludes untp:MoveEvent ;
    schema:rangeIncludes untp:Facility .

untp:trustmark a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "trustmark" ;
    rdfs:comment "A trust mark as a small binary image encoded as base64 with a description.  Maye be displayed on the conformity credential rendering.",
        "The trust mark image awarded by the AB to the CAB to indicate accreditation.",
        "The trust mark or seal used by this conformity scheme." ;
    schema:domainIncludes untp:ConformityAttestation,
        untp:ConformityScheme,
        untp:Endorsement ;
    schema:rangeIncludes untp:Image .

untp:type a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "type" ;
    rdfs:comment "The type of status list - must be set to \"The type property MUST be BitstringStatusListEntry.\"" ;
    schema:domainIncludes untp:BitstringStatusListEntry ;
    schema:rangeIncludes xsd:string .

untp:unit a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "unit" ;
    rdfs:comment "Unit of measure drawn from the UNECE Rec20 measure code list." ;
    schema:domainIncludes untp:Measure ;
    schema:rangeIncludes untp:UnitOfMeasure .

untp:upperTolerance a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "upperTolerance" ;
    rdfs:comment "The upper tolerance associated with this measure expressed in the same units as the measure.  For example value=10, upperTolerance=0.1, unit=KGM would mean that this measure is 10kg + 0.1kg" ;
    schema:domainIncludes untp:Measure ;
    schema:rangeIncludes xsd:double .

untp:url a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "url" ;
    rdfs:comment "URL for remotely hosted template" ;
    schema:domainIncludes untp:RenderTemplate2024 ;
    schema:rangeIncludes xsd:anyURI .

untp:validFrom a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "validFrom" ;
    rdfs:comment "The data from which this scheme version is valid." ;
    schema:domainIncludes untp:ConformityProfile ;
    schema:rangeIncludes xsd:date .

untp:value a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "value" ;
    rdfs:comment "The numeric value of the measure" ;
    schema:domainIncludes untp:Measure ;
    schema:rangeIncludes xsd:double .

untp:vendor a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "vendor" ;
    rdfs:comment "The vendor of the software product that issued the parent credential." ;
    schema:domainIncludes untp:IssuingSoftware ;
    schema:rangeIncludes untp:SoftwareVendor .

untp:version a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "version" ;
    rdfs:comment "The major.minor version of the criterion. Minor versions represent changes that would not invalidate an assessment made under a previous version.",
        "Version of this scheme following SemVer best practice (major.minor.patch). " ;
    schema:domainIncludes untp:ConformityProfile,
        untp:Criterion,
        untp:IssuingSoftware ;
    schema:rangeIncludes xsd:string .

untp:volume a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "volume" ;
    rdfs:comment "The displacement volume of the product. eg {\"value\":7.5, \"unit\":\"LTR\"}" ;
    schema:domainIncludes untp:Dimension ;
    schema:rangeIncludes untp:Measure .

untp:weight a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "weight" ;
    rdfs:comment "the weight of the product. EG {\"value\":10, \"unit\":\"KGM\"}" ;
    schema:domainIncludes untp:Dimension ;
    schema:rangeIncludes untp:Measure .

untp:width a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "width" ;
    rdfs:comment "The width of the product or packaging. eg {\"value\":150, \"unit\":\"MMT\"}" ;
    schema:domainIncludes untp:Dimension ;
    schema:rangeIncludes untp:Measure .

